    else finalX = x - x % SQUARESIZE + SQUARESIZE / 2;
    if (itemY % 2 == 1) finalY = y - y % SQUARESIZE + SQUARESIZE / 2;
    else finalY = y - y % SQUARESIZE + SQUARESIZE / 2;
    return [
        finalX,
        finalY
    ];
}

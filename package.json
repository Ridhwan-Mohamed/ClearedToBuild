{
  "name": "processv2",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "start": "parcel ./src/index.html",
    "start:navmesh-lab": "parcel ./src/examples/navmesh-lab/index.html",
    "start:clean": "powershell -Command \"Remove-Item -Recurse -Force dist,.parcel-cache -ErrorAction SilentlyContinue; parcel ./src/index.html\"",
    "build:main": "parcel build ./src/index.html --public-url /Pillage-The-Village-/ --dist-dir dist --no-scope-hoist",
    "build:navmesh-lab": "parcel build ./src/examples/navmesh-lab/index.html --public-url /Pillage-The-Village-/examples/navmesh-lab/ --dist-dir dist/examples/navmesh-lab --no-scope-hoist",
    "build": "powershell -Command \"Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue; npm run build:main; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; npm run build:navmesh-lab; exit $LASTEXITCODE\"",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "easystarjs": "^0.4.4",
    "glslify": "^7.1.1",
    "javascript-astar": "^0.4.2",
    "matter": "^0.2.0",
    "navmesh": "^2.3.1",
    "noisejs": "^2.1.0",
    "phaser": "^3.90.0",
    "phaser-navmesh": "^2.3.1",
    "phaser3-rex-plugins": "^1.80.16",
    "process": "^0.11.10"
  },
  "devDependencies": {
    "@parcel/transformer-webmanifest": "^2.15.4",
    "gh-pages": "^6.3.0",
    "glslify-bundle": "^5.1.1",
    "glslify-deps": "^1.3.2",
    "parcel": "^2.15.4",
    "parcel-plugin-glslify": "^0.1.0",
    "parcel-plugin-static-files-copy": "^2.6.0",
    "typescript": "^5.8.3"
  },
  "staticFiles": {
    "staticPath": "./src/shaders",
    "watcherGlob": "**"
  }
}
